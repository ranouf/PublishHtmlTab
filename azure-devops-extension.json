{
  "manifestVersion": 1,
  "id": "publish-html-tab",
  "publisher": "ranouf",
  "version": "1.20260328.15880",
  "author": "ranouf",
  "name": "Publish Html Tab",
  "description": "Publish HTML reports in Azure Pipelines",
  "public": true,
  "categories": [
    "Azure Pipelines"
  ],
  "icons": {
    "default": "icon.png"
  },
  "tags": [
    "Preview"
  ],
  "targets": [
    {
      "id": "Microsoft.VisualStudio.Services"
    }
  ],
  "repository": {
    "type": "git",
    "uri": "https://github.com/ranouf/PublishHtmlTab"
  },
  "links": {
    "repository": {
      "uri": "https://github.com/ranouf/PublishHtmlTab"
    },
    "support": {
      "uri": "https://github.com/ranouf/PublishHtmlTab/issues"
    },
    "privacypolicy": {
      "uri": "https://github.com/ranouf/PublishHtmlTab/blob/main/PRIVACY.md"
    }
  },
  "content": {
    "details": {
      "path": "OVERVIEW.md"
    },
    "license": {
      "path": "LICENSE"
    }
  },
  "scopes": [
    "vso.build"
  ],
  "demands": [
    "api-version/3.0"
  ],
  "contributions": [
    {
      "id": "build-publish-html-tab",
      "type": "ms.vss-build-web.build-results-tab",
      "description": "Embed HTML files viewer in Azure Pipelines Release",
      "targets": [
        "ms.vss-build-web.build-results-view"
      ],
      "properties": {
        "name": "HTML Viewer",
        "uri": "dist/tabContent.html",
        "registeredObjectId": "registerBuild",
        "supportsTasks": [
          "88e6171a-9e19-4b26-b78f-130dae5eebe5"
        ],
        "dynamic": true
      },
      "includes": [
        "ms.vss-releaseManagement-web.release-service-data-external"
      ]
    },
    {
      "id": "PublishHtmlTab",
      "type": "ms.vss-distributed-task.task",
      "targets": [
        "ms.vss-distributed-task.tasks"
      ],
      "properties": {
        "name": "PublishHtmlReport",
        "displayName": "Publish HTML Tab"
      }
    },
    {
      "id": "publish-html-tab-settings",
      "type": "ms.vss-web.hub",
      "targets": [
        "ms.vss-web.collection-admin-hub-group"
      ],
      "properties": {
        "name": "Publish HTML Tab",
        "uri": "dist/settings.html"
      }
    }
  ],
  "files": [
    {
      "path": "./PublishHtmlReport",
      "packagePath": "PublishHtmlReport",
      "addressable": false
    },
    {
      "path": "./dist",
      "packagePath": "dist",
      "addressable": true,
      "contentType": "application/octet-stream"
    }
  ]
}
